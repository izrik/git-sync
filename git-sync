#!/usr/bin/env python3
"""
git-sync: Synchronize local git branches with all configured remotes.

For each local branch in each repo, git-sync will:
  - Fetch all remotes
  - Fast-forward the local branch if any remote is strictly ahead (and linear)
  - Push to remotes that are strictly behind the local branch
  - Warn (without modifying anything) if branches have diverged

Divergence between any two refs (local or remote) for a given branch will
cause that branch to be skipped entirely with a warning.
"""

import subprocess
import sys
import argparse
from pathlib import Path


def git(args, cwd):
    return subprocess.run(
        ['git'] + args, cwd=str(cwd),
        capture_output=True, text=True
    )


def is_ancestor(repo, ref_a, ref_b):
    """True if ref_a is an ancestor of ref_b (or they are the same commit)."""
    r = git(['merge-base', '--is-ancestor', ref_a, ref_b], cwd=repo)
    return r.returncode == 0


def ref_exists(repo, ref):
    r = git(['rev-parse', '--verify', '--quiet', ref], cwd=repo)
    return r.returncode == 0


def count_ahead(repo, ref_from, ref_to):
    """Number of commits in ref_from not reachable from ref_to."""
    r = git(['rev-list', '--count', f'{ref_to}..{ref_from}'], cwd=repo)
    return int(r.stdout.strip()) if r.returncode == 0 else 0


def get_sha(repo, ref):
    r = git(['rev-parse', ref], cwd=repo)
    return r.stdout.strip() if r.returncode == 0 else None


def sync_repo(repo: Path, dry_run: bool = False, verbose: bool = False):
    print(f'\n{"=" * 60}')
    print(f'  {repo}')
    print(f'{"=" * 60}')

    # Get remotes
    r = git(['remote'], cwd=repo)
    remotes = r.stdout.strip().splitlines() if r.stdout.strip() else []
    if not remotes:
        print('  (no remotes configured, skipping)')
        return

    # Fetch all remotes
    for remote in remotes:
        print(f'  Fetching {remote}...')
        r = git(['fetch', '--prune', remote], cwd=repo)
        if r.returncode != 0:
            print(f'  WARNING: fetch {remote} failed: {r.stderr.strip()}')

    # Detect current branch (None if detached HEAD)
    r = git(['rev-parse', '--abbrev-ref', 'HEAD'], cwd=repo)
    current_branch = r.stdout.strip() if r.returncode == 0 else None
    if current_branch == 'HEAD':
        current_branch = None

    # Get all local branches
    r = git(['branch', '--format=%(refname:short)'], cwd=repo)
    local_branches = r.stdout.strip().splitlines() if r.stdout.strip() else []

    remote_only_branches = set()

    for branch in local_branches:
        # Map remote name -> remote ref for remotes that have this branch
        remote_refs = {
            remote: f'{remote}/{branch}'
            for remote in remotes
            if ref_exists(repo, f'{remote}/{branch}')
        }
        remotes_without_branch = [r for r in remotes if r not in remote_refs]

        if not remote_refs and not remotes_without_branch:
            continue

        # Find the single "most advanced" ref across local + all remotes.
        # If any two refs are diverged (neither is an ancestor of the other),
        # skip this branch with a warning.
        all_refs = [branch] + list(remote_refs.values())
        max_ref = branch
        conflict = None

        for ref in all_refs[1:]:
            if is_ancestor(repo, max_ref, ref):
                max_ref = ref          # ref is strictly ahead of current max
            elif is_ancestor(repo, ref, max_ref):
                pass                   # max is already at or ahead of ref
            else:
                conflict = ref
                break

        if conflict:
            print(f'  ! {branch}: diverged ({max_ref} vs {conflict}), skipping')
            continue

        max_sha = get_sha(repo, max_ref)
        local_sha = get_sha(repo, branch)
        any_action = False

        # --- Fast-forward local if it is behind max_ref ---
        if local_sha != max_sha:
            n = count_ahead(repo, max_ref, branch)
            tag = '[dry-run] ' if dry_run else ''
            print(f'  {tag}{branch}: fast-forwarding {n} commit(s) from {max_ref}')
            any_action = True
            if not dry_run:
                if branch == current_branch:
                    r = git(['merge', '--ff-only', max_ref], cwd=repo)
                else:
                    # Update the branch pointer without touching the working tree
                    r = git(['update-ref', f'refs/heads/{branch}', max_ref], cwd=repo)
                if r.returncode != 0:
                    print(f'  WARNING: fast-forward failed: {r.stderr.strip()}')
                    continue

        # --- Push to remotes whose ref is behind max_ref ---
        for remote, remote_ref in remote_refs.items():
            if get_sha(repo, remote_ref) != max_sha:
                n = count_ahead(repo, max_ref, remote_ref)
                tag = '[dry-run] ' if dry_run else ''
                print(f'  {tag}{branch}: pushing {n} commit(s) to {remote}')
                any_action = True
                if not dry_run:
                    r = git(['push', remote, f'{branch}:{branch}'], cwd=repo)
                    if r.returncode != 0:
                        print(f'  WARNING: push to {remote} failed: {r.stderr.strip()}')

        # --- Push to remotes that don't have this branch at all ---
        for remote in remotes_without_branch:
            tag = '[dry-run] ' if dry_run else ''
            print(f'  {tag}{branch}: pushing new branch to {remote}')
            any_action = True
            if not dry_run:
                r = git(['push', remote, f'{branch}:{branch}'], cwd=repo)
                if r.returncode != 0:
                    print(f'  WARNING: push new branch to {remote} failed: {r.stderr.strip()}')

        if not any_action and verbose:
            print(f'  {branch}: in sync across all remotes')

    # --- Report branches that exist on remotes but not locally ---
    for remote in remotes:
        r = git(['branch', '-r', '--format=%(refname:short)'], cwd=repo)
        for ref in r.stdout.strip().splitlines():
            if not ref.startswith(f'{remote}/'):
                continue
            branch_name = ref[len(remote) + 1:]
            if branch_name == 'HEAD' or '->' in branch_name:
                continue
            if branch_name not in local_branches:
                remote_only_branches.add((remote, branch_name))

    for remote, branch in sorted(remote_only_branches):
        print(f'  ~ {remote}/{branch}: exists on remote but not locally (skipping)')


def find_repos(paths):
    """
    For each path:
      - If it is itself a git repo, include it directly.
      - Otherwise treat it as a directory and include any immediate
        subdirectories that are git repos.
    """
    repos = []
    seen = set()
    for p in paths:
        path = Path(p).resolve()
        if (path / '.git').exists():
            if path not in seen:
                repos.append(path)
                seen.add(path)
        elif path.is_dir():
            for child in sorted(path.iterdir()):
                if child.is_dir() and (child / '.git').exists():
                    if child not in seen:
                        repos.append(child)
                        seen.add(child)
        else:
            print(f'WARNING: {p} is not a directory or git repo, skipping.', file=sys.stderr)
    return repos


def main():
    parser = argparse.ArgumentParser(
        description='Synchronize local git branches with all configured remotes.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        'paths', nargs='*', default=['.'],
        metavar='PATH',
        help=(
            'Git repo or directory containing git repos. '
            'If a directory is given, its immediate subdirectories are '
            'scanned for repos. (default: current directory)'
        ),
    )
    parser.add_argument(
        '-n', '--dry-run', action='store_true',
        help='Show what would be done without making any changes',
    )
    parser.add_argument(
        '-v', '--verbose', action='store_true',
        help='Also report branches that are already in sync',
    )
    args = parser.parse_args()

    repos = find_repos(args.paths)
    if not repos:
        print('No git repositories found.', file=sys.stderr)
        sys.exit(1)

    for repo in repos:
        sync_repo(repo, dry_run=args.dry_run, verbose=args.verbose)

    print()


if __name__ == '__main__':
    main()
